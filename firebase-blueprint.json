{
  "entities": {
    "FitnessProfile": {
      "title": "Fitness Profile",
      "description": "Personal fitness goals, tracking, and health metrics for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "height": { "type": "number", "description": "User's height in cm." },
        "targetWeight": { "type": "number" },
        "currentWeight": { "type": "number" },
        "dailyWaterGoal": { "type": "integer", "description": "Daily water intake goal in ml." },
        "currentWaterIntake": { "type": "integer", "description": "Today's water intake in ml." },
        "dailyStepGoal": { "type": "integer" },
        "currentSteps": { "type": "integer" },
        "caloriesBurned": { "type": "integer" },
        "micronutrients": {
          "type": "object",
          "properties": {
            "vitaminD": { "type": "number", "description": "mcg" },
            "omega3": { "type": "number", "description": "mg" },
            "iron": { "type": "number", "description": "mg" },
            "calcium": { "type": "number", "description": "mg" }
          }
        },
        "foodLibrary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "calories": { "type": "integer" },
              "giScore": { "type": "integer" },
              "isFavorite": { "type": "boolean" }
            }
          }
        },
        "giTracking": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mealName": { "type": "string" },
              "giScore": { "type": "integer" },
              "date": { "type": "string", "format": "date-time" }
            }
          }
        },
        "workoutSchedule": {
          "type": "array",
          "items": { "type": "string", "enum": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"] }
        },
        "personalRecords": {
          "type": "object",
          "properties": {
            "maxRunDistance": { "type": "number" },
            "maxPushups": { "type": "integer" },
            "maxPlankTime": { "type": "integer", "description": "seconds" }
          }
        },
        "painFatigueLogs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string", "format": "date-time" },
              "painScore": { "type": "integer", "minimum": 0, "maximum": 10 },
              "fatigueScore": { "type": "integer", "minimum": 0, "maximum": 10 }
            }
          }
        },
        "stravaConnected": { "type": "boolean" },
        "sleepLogs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string", "format": "date" },
              "hours": { "type": "number" },
              "quality": { "type": "integer", "minimum": 1, "maximum": 5 }
            }
          }
        },
        "achievements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "dateEarned": { "type": "string", "format": "date-time" }
            }
          }
        },
        "streakCount": { "type": "integer" },
        "lastLoginDate": { "type": "string", "format": "date" },
        "coachAccessCode": { "type": "string" },
        "mealPlan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "meals": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack"] },
                    "description": { "type": "string" },
                    "calories": { "type": "integer" }
                  }
                }
              }
            }
          }
        },
        "workouts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "duration": { "type": "integer", "description": "Duration in minutes." },
              "intensity": { "type": "string", "enum": ["low", "medium", "high"] },
              "date": { "type": "string", "format": "date-time" }
            }
          }
        },
        "healthAppConnected": { "type": "boolean", "description": "Whether the user has connected Apple Health or Google Fit." },
        "beforePhotoUrl": { "type": "string", "format": "uri", "description": "URL to the user's 'before' transformation photo." },
        "afterPhotoUrl": { "type": "string", "format": "uri", "description": "URL to the user's 'after' transformation photo." },
        "favoriteRecipes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of IDs of favorite recipes."
        },
        "lastSync": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information, preferences, and overall journey progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "partnerId": { "type": "string", "description": "UID of the partner user." },
        "coupleId": { "type": "string", "description": "Shared ID for the couple." },
        "loveLanguage": { "type": "string", "description": "Result of the love language quiz." },
        "coupleTitle": { "type": "string", "description": "Earned title based on progress." },
        "preferences": {
          "type": "object",
          "description": "User's app preferences (e.g., theme, notifications).",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark"] },
            "language": { "type": "string", "enum": ["he", "en"] },
            "onboardingCompleted": { "type": "boolean", "description": "Whether the user has completed the onboarding flow." },
            "customAvatar": { "type": "string", "description": "URL to the user's custom uploaded avatar." }
          }
        },
        "progress": {
          "type": "object",
          "description": "Overall journey progress metrics.",
          "properties": {
            "cookedCount": { "type": "integer", "description": "Number of recipes cooked." },
            "watchedMoviesCount": { "type": "integer", "description": "Number of movies watched." },
            "solvedRiddlesCount": { "type": "integer", "description": "Number of riddles solved." },
            "totalPoints": { "type": "integer", "description": "Total points earned." },
            "missionsCompleted": { "type": "integer", "description": "Number of weekly missions completed." }
          }
        },
        "credits": { "type": "integer", "description": "User's store credits or balance." },
        "medals": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of medals or achievements awarded to the user."
        },
        "points": { "type": "integer", "description": "Total points earned." },
        "missionsCompleted": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of completed mission IDs." 
        },
        "completedModuleTasks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of completed guided module task IDs."
        },
        "completedSparks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of completed daily spark IDs."
        },
        "fantasies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "isRevealed": { "type": "boolean" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          },
          "description": "List of user's intimate fantasies."
        },
        "intimacyPin": {
          "type": "string",
          "description": "PIN code to unlock the intimacy profile."
        },
        "missionDueDates": {
          "type": "object",
          "description": "Custom due dates set by the user for specific missions."
        },
        "status": { "type": "string", "enum": ["active", "disabled"], "description": "Account status." },
        "role": { "type": "string", "enum": ["user", "admin", "partner"], "description": "User's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated." }
      },
      "required": ["uid", "email"]
    },
    "CoupleMemory": {
      "title": "Couple Memory",
